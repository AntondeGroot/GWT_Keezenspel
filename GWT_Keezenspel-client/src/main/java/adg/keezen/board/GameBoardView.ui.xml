<ui:UiBinder xmlns:ui="urn:ui:com.google.gwt.uibinder"
  xmlns:g="urn:import:com.google.gwt.user.client.ui">
  <g:HorizontalPanel ui:field="columnsContainer" styleName="gameContainer">
    <g:HorizontalPanel styleName="column1">
      <g:HorizontalPanel styleName="columnWrapper">
        <g:VerticalPanel>
          <g:HTMLPanel ui:field="canvasWrapper" styleName="canvasWrapper">
            <!-- for canvas use regular id="" -->
            <!-- do not use ui:field, see below: -->
            <canvas id="canvasCards2" width="700" height="600"/>
            <g:HTMLPanel ui:field="tileBoard" width="700" height="600"/>
            <g:HTMLPanel ui:field="pawnBoard" width="700" height="600"/>
          </g:HTMLPanel>
          <g:FlowPanel ui:field="cardsContainer" styleName="cardsContainer"/>
          <g:Label ui:field="cardHintLabel" styleName="cardHintLabel"/>
        </g:VerticalPanel>
        <g:Label styleName="errorLabel" ui:field="errorLabel"/>
        <g:VerticalPanel styleName="buttonContainer">
          <g:HTMLPanel ui:field="sendButtonWrapper" styleName="sendButtonWrapper">
            <g:Button ui:field="sendButton" styleName="sendButton"/>
          </g:HTMLPanel>
          <g:Button ui:field="forfeitButton" styleName="forfeitButton"/>
          <g:Button ui:field="leaveGameButton" styleName="leaveGameButton"/>
          <g:HorizontalPanel ui:field="pawnIntegerBoxes" styleName="pawnIntegerBoxes">
            <g:Label ui:field="pawn1Label" styleName="TextBoxLabel pawn1Label"/>
            <g:TextBox ui:field="stepsPawn1" styleName="TextBoxForPawnSteps TextBoxForPawnSteps1"/>
            <g:Label ui:field="pawn2Label" styleName="TextBoxLabel pawn2Label"/>
            <g:TextBox ui:field="stepsPawn2" styleName="TextBoxForPawnSteps TextBoxForPawnSteps2"/>
          </g:HorizontalPanel>
        </g:VerticalPanel>
      </g:HorizontalPanel>
    </g:HorizontalPanel>
    <g:VerticalPanel styleName="column2">
      <g:VerticalPanel ui:field="playerListContainer2" styleName="playerListContainer"
        width="320px"/>
      <g:VerticalPanel styleName="chatContainer">
        <g:TextArea ui:field="chatDisplayField" styleName="chatDisplayField" visibleLines="8" readOnly="true"/>
        <g:HorizontalPanel ui:field="chatInputRow" styleName="chatInputRow">
          <g:TextBox ui:field="chatInputField" styleName="chatInputField"/>
          <g:Button ui:field="chatSendButton" styleName="chatSendButton"/>
        </g:HorizontalPanel>
      </g:VerticalPanel>
    </g:VerticalPanel>
  </g:HorizontalPanel>
</ui:UiBinder>
  <!-- when redrawing a canvas it gives problems and not update it-->
  <!-- instead: use DOM.getElementByID() -->
  <!-- Example: when you draw rect() before a true if-statement it will draw fine -->
  <!-- But when placed in a true if-statement it will not draw whatsoever -->